    <string name="onb_q1_not_sure">I\'m not sure yet</string>

    <string name="onb_q2_title">How would you describe your relationship with eating lately?</string>
    <string name="onb_q2_tense_rules">Tense, or full of rules</string>
    <string name="onb_q2_out_of_control">Out of my control at times</string>
    <string name="onb_q2_undo_after">Something I try to undo afterwards</string>
    <string name="onb_q2_sensory_hard">Hard because of how foods feel, taste, or seem</string>
