    <string name="onb_closing_title">Thank you for sharing</string>
    <string name="onb_closing_body">Aspen will gently shape itself around what you\'ve said, and you can change any of this anytime. One thing worth saying clearly: this isn\'t a diagnosis or an assessment. If you\'d like to find real, specialist support, here\'s where to start.</string>
    <string name="onb_closing_find_help">Find real support</string>
    <string name="onb_closing_continue">Go to Aspen</string>

