<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Companion check-ins (FR-8): requested at runtime ONLY inside the explicit opt-in flow;
         Aspen never asks for notification access outside that user act. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Phase 6 (docs/08 §1-2): ONLY for the user-initiated optional account/AI calls. Aspen has
         no analytics, no background network; with no account and no AI consent, nothing egresses. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:label="@string/app_name_android"
        android:supportsRtl="true"
        android:theme="@style/Theme.Aspen">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Aspen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
